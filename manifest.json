{
  "display_information": {
    "name": "Interview Scheduler"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Interview Scheduler",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/schedule-interview",
        "description": "Start or post an interview scheduling workflow",
        "usage_hint": "[button]",
        "should_escape": false
      },
      {
        "command": "/slack-scheduler",
        "description": "Admin commands: refresh-jazz to reload JazzHR cache",
        "usage_hint": "[refresh-jazz]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:read",
        "channels:history",
        "chat:write",
        "commands",
        "im:history",
        "im:write",
        "users:read",
        "users:read.email"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": ["app_home_opened", "message.channels", "message.im"]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
