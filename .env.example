# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# JazzHR
JAZZHR_API_KEY=
# Optional safety cap for applicant pagination
JAZZHR_APPLICANT_MAX_PAGES=500
# Max parallel applicant pages to fetch during cache refresh
JAZZHR_APPLICANT_FETCH_CONCURRENCY=2
# Set true to force a JazzHR cache refresh on every app startup
JAZZHR_REFRESH_ON_STARTUP=false
# Live candidate search pagination from the Slack intake modal
JAZZHR_LIVE_SEARCH_RESULT_PAGE_SIZE=20
JAZZHR_LIVE_SEARCH_CONCURRENCY=2
JAZZHR_LIVE_SEARCH_MAX_PAGES=10
JAZZHR_LIVE_SEARCH_SESSION_TTL_MS=900000

# Google OAuth (Calendar + Gmail)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
GOOGLE_SHARED_CALENDAR_ID=your-calendar-id@example.com
# Optional: Slack user ID whose connected Google account is used for all users
GOOGLE_AUTH_SLACK_USER_ID=

# Email safety mode. When enabled, Gmail sends go only to EMAIL_TEST_RECIPIENT
# and Google Calendar attendee update emails are disabled.
EMAIL_TEST_MODE=false
EMAIL_TEST_RECIPIENT=jamalalbadi03@gmail.com

# Encryption key for Google OAuth tokens at rest
APP_ENCRYPTION_KEY=

# Database (Postgres; if unset, falls back to JSON file store)
DATABASE_URL=

# Recruiter phone/Zoom export (Google Apps Script JSON endpoint)
RECRUITER_PHONE_EXPORT_URL=
RECRUITER_PHONE_EXPORT_TOKEN=
RECRUITER_PHONE_EXPORT_FILE_ID=
RECRUITER_PHONE_EXPORT_SHEET_NAME=

# Role/recruiter/HM assignment export (Google Apps Script JSON endpoint)
# URL/token fall back to RECRUITER_PHONE_EXPORT_URL/TOKEN when the same Apps Script deployment is reused.
ROLE_ASSIGNMENT_EXPORT_URL=
ROLE_ASSIGNMENT_EXPORT_TOKEN=
ROLE_ASSIGNMENT_EXPORT_FILE_ID=
ROLE_ASSIGNMENT_EXPORT_SHEET_NAME=
ROLE_ASSIGNMENT_EXPORT_SHEET_GID=

# Automated candidate/recruiter notifications
AUTOMATED_NOTIFICATIONS_ENABLED=false
NOTIFICATION_POLL_INTERVAL_MS=60000
FEEDBACK_FORM_URL=
RESUME_ATTACHMENT_MAX_BYTES=15728640
