# JazzHR API
JAZZHR_API_KEY=your-jazzhr-api-key

# Google OAuth (Calendar + Gmail)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Optional: defaults to {PUBLIC_BASE_URL}/oauth/google/callback if not set.
# You must register this exact URI in Google Cloud Console under the OAuth client's
# "Authorized redirect URIs". For local dev, add: http://localhost:3000/oauth/google/callback
GOOGLE_REDIRECT_URI=
GOOGLE_SHARED_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# Optional: Slack user ID whose connected Google account is used for all users
GOOGLE_AUTH_SLACK_USER_ID=

# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Optional
SLACK_POSTING_CHANNEL_ID=
SLACK_RECRUITMENT_CHANNEL_ID=
SLACK_TEAM_ID=

# Encryption key for Google OAuth tokens at rest
APP_ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# Optional: public base URL for the app (used to construct the OAuth redirect URI)
# PUBLIC_BASE_URL=http://localhost:3000

# JazzHR pagination
JAZZHR_APPLICANT_MAX_PAGES=500
JAZZHR_APPLICANT_FETCH_CONCURRENCY=2
JAZZHR_REFRESH_ON_STARTUP=false
JAZZHR_LIVE_SEARCH_MAX_PAGES=10

# Recruiter phone/Zoom export (Google Apps Script)
RECRUITER_PHONE_EXPORT_URL=
RECRUITER_PHONE_EXPORT_TOKEN=
RECRUITER_PHONE_EXPORT_FILE_ID=
RECRUITER_PHONE_EXPORT_SHEET_NAME=

# Role assignment export
ROLE_ASSIGNMENT_EXPORT_FILE_ID=
ROLE_ASSIGNMENT_EXPORT_SHEET_GID=
ROLE_ASSIGNMENT_EXPORT_URL=

# Email safety mode
EMAIL_TEST_MODE=false
EMAIL_TEST_RECIPIENT=

# Scheduling
SCHEDULING_TIME_ZONES=Australia/Sydney,Asia/Manila,America/Los_Angeles,America/New_York,Europe/London
