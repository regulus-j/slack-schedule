{
  "name": "slack-scheduler",
  "version": "0.0.0",
  "description": "Slack-first interview scheduling assistant for JazzHR, Google Calendar, and Gmail workflows",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "test": "node --test",
    "check": "node --check app.js",
    "migrate": "node scripts/migrate.js",
    "notifications:test": "node scripts/notifications-cli.js",
    "retention": "node scripts/retention.js",
    "legal-hold": "node scripts/legal-hold.js",
    "tokens:reencrypt": "node scripts/reencrypt-google-tokens.js",
    "security:audit": "npm audit --omit=dev --audit-level=moderate"
  },
  "license": "MIT",
  "dependencies": {
    "@google-cloud/cloud-sql-connector": "1.11.1",
    "@google-cloud/kms": "5.5.1",
    "@slack/bolt": "4.7.3",
    "form-data": "4.0.6",
    "pg": "8.22.0",
    "qs": "6.15.2",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@slack/cli-hooks": "^1.3.2",
    "@types/node": "^26.0.1"
  },
  "author": "regulus-j Jamal A. Al Badi"
}
